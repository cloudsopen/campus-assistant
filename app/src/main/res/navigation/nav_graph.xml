<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.campusassistant.ui.HomeFragment"
        android:label="首页"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_aid"
        android:name="com.example.campusassistant.ui.AidFragment"
        android:label="互助"
        tools:layout="@layout/fragment_aid" />

    <fragment
        android:id="@+id/navigation_publish"
        android:name="com.example.campusassistant.ui.PublishFragment"
        android:label="发布"
        tools:layout="@layout/fragment_publish" />

    <fragment
        android:id="@+id/navigation_messages"
        android:name="com.example.campusassistant.ui.MessagesFragment"
        android:label="消息"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.campusassistant.ui.ProfileFragment"
        android:label="我的"
        tools:layout="@layout/fragment_profile" />
</navigation>
