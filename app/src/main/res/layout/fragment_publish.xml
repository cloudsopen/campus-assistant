<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_publish_header_new"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_publish_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="发布中心"
                android:textColor="#1A237E"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_publish_title"
                android:layout_marginTop="8dp"
                android:id="@+id/tv_daily_quote"
                android:textColor="#5C6BC0"
                android:textSize="16sp" />
        </RelativeLayout>

        <!-- Today's Hot Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_publish_card_white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="8dp"
                android:text="今日热门"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                app:drawableTint="#333333" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_count_idle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#42A5F5" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="闲置" android:textColor="#666666" android:textSize="12sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_count_buy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#42A5F5" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="求购" android:textColor="#666666" android:textSize="12sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_count_carpool" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#42A5F5" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="拼车" android:textColor="#666666" android:textSize="12sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_count_errand" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#42A5F5" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="跑腿" android:textColor="#666666" android:textSize="12sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#EEEEEE" android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_count_lost" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#42A5F5" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="寻物" android:textColor="#666666" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Publish Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_publish_card_white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快速发布"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="5">

                <!-- Publish 1: 闲置物品 -->
                <LinearLayout
                    android:id="@+id/layout_publish_idle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_category_icon"
                        android:backgroundTint="#FFB300"
                        android:padding="10dp"
                        android:src="@drawable/ic_home"
                        app:tint="@android:color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="闲置" android:textColor="#333333" android:textSize="12sp" />
                </LinearLayout>

                <!-- Publish 2: 求购 -->
                <LinearLayout
                    android:id="@+id/layout_publish_buy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_category_icon"
                        android:backgroundTint="#9575CD"
                        android:padding="10dp"
                        android:src="@drawable/ic_message"
                        app:tint="@android:color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="求购" android:textColor="#333333" android:textSize="12sp" />
                </LinearLayout>

                <!-- Publish 3: 拼车 -->
                <LinearLayout
                    android:id="@+id/layout_publish_carpool"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_category_icon"
                        android:backgroundTint="#26A69A"
                        android:padding="10dp"
                        android:src="@drawable/ic_people"
                        app:tint="@android:color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="拼车" android:textColor="#333333" android:textSize="12sp" />
                </LinearLayout>

                <!-- Publish 4: 跑腿 -->
                <LinearLayout
                    android:id="@+id/layout_publish_errand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_category_icon"
                        android:backgroundTint="#42A5F5"
                        android:padding="10dp"
                        android:src="@drawable/ic_send"
                        app:tint="@android:color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="跑腿" android:textColor="#333333" android:textSize="12sp" />
                </LinearLayout>

                <!-- Publish 5: 丢失 -->
                <LinearLayout
                    android:id="@+id/layout_publish_lost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_category_icon"
                        android:backgroundTint="#EF5350"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@android:color/white" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="寻物" android:textColor="#333333" android:textSize="12sp" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <!-- My Publish Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_publish_card_white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的发布"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_view_all_publish"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="查看全部 >"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_my_publish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:listitem="@android:layout/simple_list_item_2" />

                <LinearLayout
                    android:id="@+id/layout_empty_publish"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@android:drawable/ic_menu_agenda"
                        app:tint="#EEEEEE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="暂无发布记录"
                        android:textColor="#666666"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="发布闲置、拼车、跑腿等内容"
                        android:textColor="#999999"
                        android:textSize="12sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="80dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>