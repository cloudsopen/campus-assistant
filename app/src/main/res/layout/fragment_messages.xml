<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="36dp"
        android:paddingEnd="20dp"
        android:paddingBottom="96dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="消息"
                    android:textColor="#111827"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_message_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="帖子接取和闲置购买提醒"
                    android:textColor="#6B7280"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_mark_all_read"
                android:layout_width="96dp"
                android:layout_height="38dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_idle_chip_unselected"
                android:gravity="center"
                android:text="全部已读"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_publish_card_white"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tv_unread_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无未读消息"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_messages_empty"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:gravity="center"
                android:text="暂无消息"
                android:textColor="#9CA3AF"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layout_message_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
