<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    android:clipToPadding="false"
    tools:context=".ui.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="96dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="276dp"
            android:background="@drawable/bg_home_header_gradient">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="30dp"
                android:text="一起乐校园"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="88dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_capsule_white"
                android:gravity="center"
                android:text="•••   ○"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_gravity="top"
                android:layout_marginStart="22dp"
                android:layout_marginTop="92dp"
                android:layout_marginEnd="22dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:tint="#111827" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="搜索商品、拼车、跑腿..."
                    android:textColor="#9CA3AF"
                    android:textSize="17sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="一起乐校园"
                    android:textColor="@android:color/white"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="更多 Bistuer 选择的信息科大校园生活平台"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_notice_gradient"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="校园服务持续完善中，欢迎同学们体验和反馈"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:columnCount="4"
            android:paddingStart="14dp"
            android:paddingTop="22dp"
            android:paddingEnd="14dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:id="@+id/forum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_category_icon"
                    android:padding="16dp"
                    android:src="@drawable/ic_note"
                    android:tint="#111827" />

                <TextView
                    style="@style/HomeCategoryTitle"
                    android:text="纯净墙" />

                <TextView
                    style="@style/HomeCategorySubtitle"
                    android:text="点我点我" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/second_hand_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_category_icon"
                    android:padding="16dp"
                    android:src="@drawable/ic_box"
                    android:tint="#111827" />

                <TextView
                    style="@style/HomeCategoryTitle"
                    android:text="二手闲置" />

                <TextView
                    style="@style/HomeCategorySubtitle"
                    android:text="闲置好物" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_category_icon"
                    android:padding="16dp"
                    android:src="@drawable/ic_car"
                    android:tint="#111827" />

                <TextView
                    style="@style/HomeCategoryTitle"
                    android:text="打车拼车" />

                <TextView
                    style="@style/HomeCategorySubtitle"
                    android:text="便捷出行" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lost_found_entry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_category_icon"
                    android:padding="16dp"
                    android:src="@drawable/ic_search"
                    android:tint="#111827" />

                <TextView
                    style="@style/HomeCategoryTitle"
                    android:text="寻物招领" />

                <TextView
                    style="@style/HomeCategorySubtitle"
                    android:text="失物找回" />
            </LinearLayout>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#EFF3F8"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <FrameLayout
                android:layout_width="154dp"
                android:layout_height="176dp"
                android:background="@drawable/bg_campus_photo">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#80000000"
                    android:padding="10dp"
                    android:text="校园一角"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:text="二手交易、拼车互助、寻物招领都在这里。"
                android:textColor="#6B7280"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/second_hand_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_box"
                        android:tint="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="最新闲置"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/view_more_second_hand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:text="查看更多 >"
                    android:textColor="#8B8FA1"
                    android:textSize="14sp" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/preview_chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_idle_chip_selected"
                        android:gravity="center"
                        android:minWidth="82dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="全部"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/preview_chip_books"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_idle_chip_unselected"
                        android:gravity="center"
                        android:minWidth="96dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="图书教材"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/preview_chip_daily"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_idle_chip_unselected"
                        android:gravity="center"
                        android:minWidth="96dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="生活用品"
                        android:textColor="#111827"
                        android:textSize="14sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_publish_card_white"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="闲置大厅已支持分类浏览入口"
                    android:textColor="#111827"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="目前先保留顶部分类和跳转功能，具体闲置商品后续可以继续接入数据库展示。"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btn_enter_idle_hall"
                    android:layout_width="138dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_idle_chip_selected"
                    android:gravity="center"
                    android:text="进入闲置大厅"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="已经到底啦"
            android:textColor="#C4C8D0"
            android:textSize="13sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
