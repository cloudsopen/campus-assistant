<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="248dp"
            android:background="@drawable/bg_home_header_gradient">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33000000" />

            <ImageView
                android:id="@+id/btn_back_idle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="18dp"
                android:layout_marginTop="48dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="46dp"
                android:text="闲置大厅"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="88dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_capsule_white"
                android:gravity="center"
                android:text="•••   ○"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="34dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="闲置好物"
                    android:textColor="@android:color/white"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="发现校园宝藏"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/idle_search_box"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-22dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_search_bar"
            android:elevation="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search"
                android:tint="#6B7280" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="搜索你想要的物品"
                android:textColor="#9CA3AF"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_idle_notice"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="公告  天天开心！"
            android:textColor="#A16207"
            android:textSize="15sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/chip_all"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_idle_chip_selected"
                    android:gravity="center"
                    android:minWidth="82dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="全部"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_clothes"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_idle_chip_unselected"
                    android:gravity="center"
                    android:minWidth="112dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="服装鞋包"
                    android:textColor="#111827"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_books"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_idle_chip_unselected"
                    android:gravity="center"
                    android:minWidth="112dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="图书教材"
                    android:textColor="#111827"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_idle_chip_unselected"
                    android:gravity="center"
                    android:minWidth="112dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="生活用品"
                    android:textColor="#111827"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_sports"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_idle_chip_unselected"
                    android:gravity="center"
                    android:minWidth="112dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="运动健身"
                    android:textColor="#111827"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_digital"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_idle_chip_unselected"
                    android:gravity="center"
                    android:minWidth="112dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="数码电器"
                    android:textColor="#111827"
                    android:textSize="16sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_publish_card_white"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="最新发布"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_current_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="当前分类：全部"
                android:textColor="#6B7280"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/layout_idle_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_idle_placeholder"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_idle_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="全部 分类的闲置物品后续会展示在这里，目前可以先完善顶部分类和发布流程。"
                    android:textColor="#6B7280"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/btn_publish_idle"
                    android:layout_width="112dp"
                    android:layout_height="42dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_idle_chip_selected"
                    android:gravity="center"
                    android:text="发布闲置"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_idle_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
